{
  "servicios": {
    "slack": {
      "tipo": "webhook",
      "endpoint": null,
      "metodo": "POST",
      "campos": ["webhookUrl", "channel"],
      "icono": "💬",
      "categoria": "mensajeria"
    },
    "telegram": {
      "tipo": "api",
      "endpoint": "https://api.telegram.org/bot{botToken}/sendMessage",
      "metodo": "POST",
      "campos": ["botToken", "chatId"],
      "icono": "✈️",
      "categoria": "mensajeria"
    },
    "discord": {
      "tipo": "webhook",
      "endpoint": null,
      "metodo": "POST",
      "campos": ["webhookUrl"],
      "icono": "🎮",
      "categoria": "mensajeria"
    },
    "jira": {
      "tipo": "api",
      "endpoint": "https://{domain}.atlassian.net/rest/api/3/issue",
      "metodo": "POST",
      "campos": ["domain", "email", "apiToken", "projectKey"],
      "icono": "🔷",
      "categoria": "proyectos",
      "headers": {
        "Authorization": "Basic {credenciales}",
        "Content-Type": "application/json"
      }
    },
    "trello": {
      "tipo": "api",
      "endpoint": "https://api.trello.com/1/cards",
      "metodo": "POST",
      "campos": ["apiKey", "token", "boardId"],
      "icono": "📌",
      "categoria": "proyectos",
      "params": {
        "key": "{apiKey}",
        "token": "{token}",
        "idList": "{boardId}",
        "name": "{taskName}"
      }
    },
    "github": {
      "tipo": "api",
      "endpoint": "https://api.github.com/repos/{repo}/issues",
      "metodo": "POST",
      "campos": ["token", "repo"],
      "icono": "🐙",
      "categoria": "proyectos",
      "headers": {
        "Authorization": "Bearer {token}",
        "Content-Type": "application/json"
      }
    },
    "notion": {
      "tipo": "api",
      "endpoint": "https://api.notion.com/v1/pages",
      "metodo": "POST",
      "campos": ["apiKey", "databaseId"],
      "icono": "📄",
      "categoria": "proyectos",
      "headers": {
        "Authorization": "Bearer {apiKey}",
        "Content-Type": "application/json",
        "Notion-Version": "2022-06-28"
      }
    },
    "googleDrive": {
      "tipo": "oauth",
      "endpoint": "https://www.googleapis.com/drive/v3/files",
      "metodo": "POST",
      "campos": ["accessToken", "folderId"],
      "icono": "☁️",
      "categoria": "almacenamiento"
    },
    "airtable": {
      "tipo": "api",
      "endpoint": "https://api.airtable.com/v0/{baseId}/{tableName}",
      "metodo": "POST",
      "campos": ["apiKey", "baseId", "tableName"],
      "icono": "🗄️",
      "categoria": "bases-datos",
      "headers": {
        "Authorization": "Bearer {apiKey}",
        "Content-Type": "application/json"
      }
    },
    "hubspot": {
      "tipo": "api",
      "endpoint": "https://api.hubapi.com/crm/v3/objects/tasks",
      "metodo": "POST",
      "campos": ["apiKey"],
      "icono": "🎯",
      "categoria": "crm",
      "headers": {
        "Authorization": "Bearer {apiKey}",
        "Content-Type": "application/json"
      }
    }
  }
}